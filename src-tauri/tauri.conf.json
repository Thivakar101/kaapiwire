{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kaapiwire",
  "version": "0.1.0",
  "identifier": "com.kaapiwire.widget",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Kaapiwire",
        "width": 360,
        "height": 430,
        "minWidth": 56,
        "minHeight": 56,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": true,
        "center": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; style-src 'self'; img-src 'self'",
      "capabilities": ["main"]
    }
  },
  "bundle": {
    "active": false
  }
}
